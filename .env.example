# TsureBen environment variables (copy to .env)

# 開発サーバーで「一緒に勉強中」のデモ表示（デフォルト ON、false で無効）
# VITE_DEMO_PRESENCE=false
# 開発サーバーで連れ勉仲間リストのデモ表示（デフォルト ON、false で無効）
# VITE_DEMO_MATE=false
# デモ人数（省略時は10人）。例: 2人だけ表示して確認
# VITE_DEMO_PRESENCE_COUNT=2
# VITE_OAUTH_CLIENT_ID=77789669140-61nhedsb0v3i2qsthnsq0pm7nba0ahkr.apps.googleusercontent.com

# トークン交換 Cloud Function URL（省略時は tsureben 本番 Functions）
# VITE_OAUTH_EXCHANGE_URL=https://asia-northeast1-tsureben.cloudfunctions.net/exchangeOAuthCode
#
# Google Cloud Console（tsureben）で Web Client に以下を追加:
#   承認済みの JavaScript 生成元:
#     http://localhost:5173
#     http://127.0.0.1:5173
#   承認済みのリダイレクト URI:
#     http://localhost:5173/oauth-callback
#     http://127.0.0.1:5173/oauth-callback
# https://console.cloud.google.com/apis/credentials?project=tsureben
#
# localhost 開発時は timetable 同等の Implicit Flow を使用するため、
# GOOGLE_CLIENT_SECRET / exchangeOAuthCode は通常不要です。
#
# Authorization Code 方式を使う場合のみ:
#   firebase functions:secrets:set GOOGLE_CLIENT_SECRET
#   firebase deploy --only functions:exchangeOAuthCode
#
# AdMob（Info.plist の GADApplicationIdentifier と揃える）
# VITE_ADMOB_IOS_APP_ID=ca-app-pub-3113647340712066~2753972645
# VITE_ADMOB_IOS_BANNER_ID=ca-app-pub-3113647340712066/7312164756

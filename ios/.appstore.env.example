# App Store Connect API 認証情報のテンプレート。
# これをコピーして ios/.appstore.env を作成し、自分の値を設定する。
#   cp ios/.appstore.env.example ios/.appstore.env
# 取得元: App Store Connect > ユーザーとアクセス > インテグレーション > App Store Connect API

ASC_KEY_ID="XXXXXXXXXX"
ASC_ISSUER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
ASC_KEY_PATH="$HOME/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8"
TEAM_ID="XXXXXXXXXX"

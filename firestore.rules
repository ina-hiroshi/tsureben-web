rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function teacherDoc() {
      return get(/databases/$(database)/documents/teachers/$(userEmail()));
    }

    function isTeacher() {
      return isAuthenticated() && exists(/databases/$(database)/documents/teachers/$(userEmail()));
    }

    function teacherRole() {
      return teacherDoc().data.role;
    }

    function isSchoolAdmin() {
      return isTeacher() && teacherRole() in ['school_admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isTeacher() && teacherRole() == 'super_admin';
    }

    function teacherSchoolId() {
      let fromTeacher = teacherDoc().data.get('schoolId', null);
      return fromTeacher != null
        ? fromTeacher
        : get(/databases/$(database)/documents/users/$(userEmail())).data.get('schoolId', null);
    }

    function studentSchoolId(studentEmail) {
      return get(/databases/$(database)/documents/users/$(studentEmail)).data.get('schoolId', null);
    }

    function sameSchoolAsTarget(targetEmail) {
      let targetSchoolId = studentSchoolId(targetEmail);
      let callerSchoolId = teacherSchoolId();
      return isTeacher()
        && exists(/databases/$(database)/documents/users/$(targetEmail))
        && targetSchoolId != null
        && callerSchoolId != null
        && targetSchoolId == callerSchoolId;
    }

    function teacherCanListSchoolStudent() {
      let callerSchoolId = teacherSchoolId();
      return isTeacher()
        && callerSchoolId != null
        && resource.data.get('role', '') == 'student'
        && resource.data.get('schoolId', '') == callerSchoolId;
    }

    function callerUserDoc() {
      return get(/databases/$(database)/documents/users/$(userEmail()));
    }

    function callerUserData() {
      return callerUserDoc().data;
    }

    function isMateRelated(targetEmail) {
      return exists(/databases/$(database)/documents/users/$(userEmail()))
        && (
          targetEmail in callerUserData().get('mutualMates', [])
          || targetEmail in callerUserData().get('pendingSent', [])
          || targetEmail in callerUserData().get('pendingReceived', [])
          || targetEmail in callerUserData().get('hiddenMates', [])
          || targetEmail in callerUserData().get('hiddenRequests', [])
        );
    }

    function canReadUserProfile(targetEmail) {
      return userEmail() == targetEmail
        || isSuperAdmin()
        || (isTeacher() && sameSchoolAsTarget(targetEmail))
        || isMateRelated(targetEmail);
    }

    function canAccessUserData(targetEmail) {
      return userEmail() == targetEmail
        || (isSuperAdmin() && exists(/databases/$(database)/documents/users/$(targetEmail)))
        || (isTeacher() && sameSchoolAsTarget(targetEmail));
    }

    function profileIdentityField(data, field) {
      let v = data.get(field, '');
      return v == null ? '' : string(v);
    }

    function userProfileIdentityUnchanged() {
      return profileIdentityField(request.resource.data, 'grade') == profileIdentityField(resource.data, 'grade')
        && profileIdentityField(request.resource.data, 'class') == profileIdentityField(resource.data, 'class')
        && profileIdentityField(request.resource.data, 'number') == profileIdentityField(resource.data, 'number');
    }

    function isSelfRegisteredStudent() {
      return resource.data.get('registrationType', '') == 'self_registered';
    }

    function onlyDisplayNameFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'nameLower', 'updatedAt']);
    }

    function studentProfilePatchAllowed() {
      let k = request.resource.data.diff(resource.data).affectedKeys();
      return k.hasOnly(['shareScope', 'updatedAt'])
        || k.hasOnly(['mateScope', 'updatedAt'])
        || k.hasOnly(['mustChangePassword', 'updatedAt'])
        || k.hasOnly(['onboardingComplete', 'updatedAt'])
        || k.hasOnly(['onboardingComplete', 'mustChangePassword', 'updatedAt'])
        || k.hasOnly(['shareScope', 'mateScope', 'onboardingComplete', 'updatedAt'])
        || k.hasOnly(['shareScope', 'mateScope', 'onboardingComplete', 'mustChangePassword', 'updatedAt'])
        || k.hasOnly(['name', 'nameLower', 'updatedAt'])
        || k.hasOnly(['subjectCatalog', 'updatedAt'])
        || k.hasOnly(['shareScope', 'mateScope', 'updatedAt'])
        || k.hasOnly(['hiddenMates', 'updatedAt'])
        || k.hasOnly(['hiddenRequests', 'updatedAt']);
    }

    function canUpdateOwnUserProfile() {
      return (userProfileIdentityUnchanged() && studentProfilePatchAllowed())
        || (isSelfRegisteredStudent() && onlyDisplayNameFieldsChanged());
    }

    function userCreateAllowed() {
      let data = request.resource.data;
      return data.get('role', 'student') == 'student'
        && !('registrationType' in data)
        && !('mustChangePassword' in data)
        && (!('schoolId' in data) || data.schoolId == null)
        && data.get('mutualMates', []) == []
        && data.get('pendingSent', []) == []
        && data.get('pendingReceived', []) == []
        && data.get('hiddenMates', []) == []
        && data.get('hiddenRequests', []) == [];
    }

    function canReadActiveSession(sessionEmail, sessionData) {
      return userEmail() == sessionEmail
        || isSuperAdmin()
        || (isTeacher() && sessionData.get('schoolId', null) == teacherSchoolId())
        || userEmail() in sessionData.get('mateEmails', [])
        || activeSessionVisibleByShareScope(sessionData);
    }

    function activeSessionVisibleByShareScope(sessionData) {
      return exists(/databases/$(database)/documents/users/$(userEmail()))
        && callerUserData().get('schoolId', null) != null
        && callerUserData().get('schoolId', null) == sessionData.get('schoolId', null)
        && callerUserData().get('shareScope', '学年のみ') != '連れ勉仲間のみ'
        && (
          (
            callerUserData().get('shareScope', '学年のみ') == '学年のみ'
            && profileIdentityField(callerUserData(), 'grade') == profileIdentityField(sessionData, 'grade')
          )
          || (
            callerUserData().get('shareScope', '') == '組のみ'
            && profileIdentityField(callerUserData(), 'grade') == profileIdentityField(sessionData, 'grade')
            && profileIdentityField(callerUserData(), 'class') == profileIdentityField(sessionData, 'class')
          )
        );
    }

    function activeSessionSchoolIdValid() {
      let me = callerUserData();
      let data = request.resource.data;
      return !exists(/databases/$(database)/documents/users/$(userEmail()))
        || !('schoolId' in data)
        || data.schoolId == me.get('schoolId', null);
    }

    function feedbackThreadMetadataPatchAllowed() {
      let k = request.resource.data.diff(resource.data).affectedKeys();
      return k.hasOnly(['unreadByStudent', 'updatedAt'])
        || k.hasOnly(['unreadByTeacher', 'updatedAt'])
        || k.hasOnly(['unreadByStudent', 'unreadByTeacher', 'updatedAt'])
        || k.hasOnly(['lastMessageAt', 'updatedAt'])
        || k.hasOnly(['lastMessageAt', 'lastMessagePreview', 'updatedAt'])
        || k.hasOnly(['unreadByStudent', 'lastMessageAt', 'updatedAt'])
        || k.hasOnly(['unreadByStudent', 'lastMessageAt', 'lastMessagePreview', 'updatedAt'])
        || k.hasOnly(['unreadByTeacher', 'lastMessageAt', 'updatedAt'])
        || k.hasOnly(['unreadByTeacher', 'lastMessageAt', 'lastMessagePreview', 'updatedAt'])
        || k.hasOnly(['unreadByStudent', 'unreadByTeacher', 'lastMessageAt', 'updatedAt'])
        || k.hasOnly(['unreadByStudent', 'unreadByTeacher', 'lastMessageAt', 'lastMessagePreview', 'updatedAt']);
    }

    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /billingInvites/{email} {
      allow read, write: if false;
    }

    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    match /teachers/{email} {
      allow read: if isAuthenticated() && (userEmail() == email || isSchoolAdmin());
      allow write: if false;
    }

    match /users/{email} {
      allow get: if isAuthenticated() && canReadUserProfile(email);
      allow list: if isAuthenticated() && (isSuperAdmin() || teacherCanListSchoolStudent());
      allow create: if isAuthenticated() && userEmail() == email && userCreateAllowed();
      allow update: if isAuthenticated() && userEmail() == email
        && canUpdateOwnUserProfile();
      allow delete: if false;
    }

    match /plans/{email}/days/{dateKey} {
      allow read, write: if isAuthenticated() && canAccessUserData(email);
    }

    match /logs/{email}/days/{dateKey} {
      allow read, write: if isAuthenticated() && canAccessUserData(email);
    }

    match /activeSessions/{email} {
      allow read: if isAuthenticated() && canReadActiveSession(email, resource.data);
      allow create, update: if isAuthenticated() && userEmail() == email
        && activeSessionSchoolIdValid();
      allow delete: if isAuthenticated() && userEmail() == email;
    }

    match /verification_codes/{email} {
      allow read, write: if false;
    }

    match /mateInvites/{tokenId} {
      allow read, write: if false;
    }

    match /accountTransfers/{code} {
      allow read, write: if false;
    }

    match /schoolJoinInvites/{email} {
      allow read, write: if false;
    }

    function feedbackThreadData(threadId) {
      return get(/databases/$(database)/documents/feedbackThreads/$(threadId)).data;
    }

    function canReadFeedbackThreadData(data) {
      return userEmail() == data.studentEmail
        || isSuperAdmin()
        || (isTeacher() && sameSchoolAsTarget(data.studentEmail));
    }

    function canReadFeedbackThread(threadId) {
      return canReadFeedbackThreadData(feedbackThreadData(threadId));
    }

    match /feedbackThreads/{threadId} {
      allow read: if isAuthenticated() && canReadFeedbackThreadData(resource.data);
      allow create: if isTeacher()
        && exists(/databases/$(database)/documents/users/$(request.resource.data.studentEmail))
        && request.resource.data.schoolId == studentSchoolId(request.resource.data.studentEmail)
        && (isSuperAdmin() || sameSchoolAsTarget(request.resource.data.studentEmail));
      allow update: if isAuthenticated()
        && canReadFeedbackThreadData(resource.data)
        && feedbackThreadMetadataPatchAllowed();

      match /messages/{messageId} {
        allow read: if isAuthenticated() && canReadFeedbackThread(threadId);
        allow create: if isAuthenticated()
          && canReadFeedbackThread(threadId)
          && (
            (isTeacher() && request.resource.data.authorRole == 'teacher')
            || (userEmail() == feedbackThreadData(threadId).studentEmail
              && request.resource.data.authorRole == 'student')
          );
        allow update: if isAuthenticated()
          && canReadFeedbackThread(threadId)
          && resource.data.authorEmail == userEmail()
          && (
            (
              request.resource.data.authorEmail == resource.data.authorEmail
              && request.resource.data.authorRole == resource.data.authorRole
              && request.resource.data.authorName == resource.data.authorName
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.body is string
              && request.resource.data.body.size() > 0
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'updatedAt'])
            )
            || (
              request.resource.data.authorEmail == resource.data.authorEmail
              && request.resource.data.authorRole == resource.data.authorRole
              && request.resource.data.authorName == resource.data.authorName
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.body == resource.data.body
              && resource.data.get('deletedAt', null) == null
              && request.resource.data.deletedAt is timestamp
              && request.resource.data.deletedBy == userEmail()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletedAt', 'deletedBy'])
            )
          );
        allow delete: if false;
      }
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function teacherDoc() {
      return get(/databases/$(database)/documents/teachers/$(userEmail()));
    }

    function isTeacher() {
      return isAuthenticated() && exists(/databases/$(database)/documents/teachers/$(userEmail()));
    }

    function teacherRole() {
      return teacherDoc().data.role;
    }

    function isSchoolAdmin() {
      return isTeacher() && teacherRole() in ['school_admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isTeacher() && teacherRole() == 'super_admin';
    }

    function sameSchoolAsTarget(targetEmail) {
      return isTeacher()
        && get(/databases/$(database)/documents/users/$(targetEmail)).data.schoolId == teacherDoc().data.schoolId;
    }

    function canAccessUserData(targetEmail) {
      return userEmail() == targetEmail
        || (isTeacher() && sameSchoolAsTarget(targetEmail))
        || (isTeacher() && !exists(/databases/$(database)/documents/users/$(targetEmail)));
    }

    match /schools/{schoolId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    match /teachers/{email} {
      allow read: if isAuthenticated() && (userEmail() == email || isSchoolAdmin());
      allow write: if false;
    }

    match /users/{email} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && userEmail() == email;
      allow update: if isAuthenticated() && userEmail() == email
        && request.resource.data.grade == resource.data.get('grade', null)
        && request.resource.data.class == resource.data.get('class', null)
        && request.resource.data.number == resource.data.get('number', null);
      allow delete: if false;
    }

    match /plans/{email}/days/{dateKey} {
      allow read, write: if isAuthenticated() && canAccessUserData(email);
    }

    match /logs/{email}/days/{dateKey} {
      allow read, write: if isAuthenticated() && canAccessUserData(email);
    }

    match /activeSessions/{email} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && userEmail() == email;
    }

    match /verification_codes/{email} {
      allow read, write: if false;
    }
  }
}
